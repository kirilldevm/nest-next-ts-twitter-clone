# Firebase Web App config (get from Firebase Console > Project Settings > General > Your apps)
# These are safe to expose in the frontend - apiKey is restricted by domain in Firebase Console.
# DO NOT use service account credentials here - those are for backend only.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Your API base URL (Firebase Functions or backend)
NEXT_PUBLIC_API_URL=your-api-url

# Set to "true" when using Firebase emulators (Auth, Storage) for local development.
# Required when your API points to the Functions emulator so tokens verify correctly.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true
